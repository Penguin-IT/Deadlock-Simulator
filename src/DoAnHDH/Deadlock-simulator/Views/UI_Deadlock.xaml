<Window x:Class="Deadlock_simulator.Views.UI_Deadlock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helper="clr-namespace:Deadlock_simulator.Core"
        xmlns:local="clr-namespace:Deadlock_simulator.ViewModels"
        mc:Ignorable="d"
        Title="UI_Deadlock" Height="450" Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <!-- BUTTON -->
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,6,0,12"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

    </Window.Resources>
    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== BUTTON TOP ===== -->
        <StackPanel Orientation="Horizontal"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            Margin="0,0,0,20">

            <Button Content="▶ Bắt đầu"
            Background="#22C55E"
            Width="130"
            Style="{StaticResource BtnStyle}"/>

            <Button Content="⏸ Tạm dừng"
            Background="#F59E0B"
            Width="130"
            Style="{StaticResource BtnStyle}"/>

            <Button Content="⏭ Bước tiếp"
            Background="#3B82F6"
            Width="130"
            Style="{StaticResource BtnStyle}"/>

        </StackPanel>

        <!-- ===== INPUT PANEL ===== -->
        <Border Grid.Row="1" Grid.Column="0"
        Background="#1E293B"
        CornerRadius="15"
        Padding="20">

            <StackPanel>

                <TextBlock Text="PROCESS"
                   Foreground="#94A3B8"
                   FontWeight="Bold"
                   FontSize="14"/>

                <TextBox Style="{StaticResource TextBoxStyle}"
                 Text="{Binding NewProcessName, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="+ Thêm Process"
                Style="{StaticResource BtnStyle}"
                Background="#6366F1"
                Command="{Binding AddProcessCommand}"/>

                <TextBlock Text="RESOURCE"
                   Foreground="#94A3B8"
                   FontWeight="Bold"
                   Margin="0,20,0,0"
                   FontSize="14"/>

                <TextBox Style="{StaticResource TextBoxStyle}"
                 Text="{Binding NewResourceName, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="+ Thêm Resource"
                Style="{StaticResource BtnStyle}"
                Background="#6366F1"
                Command="{Binding AddResourceCommand}"/>

            </StackPanel>
        </Border>

        <!-- ===== DATAGRID AREA ===== -->
        <Border CornerRadius="12"
    BorderBrush="#334155"
    BorderThickness="1"
    Background="#0F172A"
    Padding="5"
    Grid.Row="1"
    Grid.Column="1"
    Margin="20">
            <DataGrid ItemsSource="{Binding Matrix}"
                  AutoGenerateColumns="False"
                  helper:DataGridHelper.BindableColumns="{Binding Columns}"
                  Grid.Row="1"
                  Grid.Column="1"
                  Margin="20"
                  Padding="10"
                  BorderBrush="#334155"
                  BorderThickness="2"
                  CanUserAddRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  SelectionUnit="Cell"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#334155"
                  VerticalGridLinesBrush="#334155"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  AlternatingRowBackground="#111827"
                  AlternationCount="2"/>
        </Border>
        <!-- ===== STYLE ===== -->
        <Grid.Resources>

            <!-- BUTTON -->
            <Style x:Key="BtnStyle" TargetType="Button">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TEXTBOX -->
            <Style x:Key="TextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="0,6,0,12"/>
                <Setter Property="Background" Value="#0F172A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#6366F1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6"/>
            </Style>
            <!-- ===== DATAGRID STYLE ===== -->
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="#0F172A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#334155"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="RowHeight" Value="40"/>
            </Style>

            <!-- HEADER -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <!-- override template -->
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Border Background="#3B82F6"
                    BorderBrush="#334155"
                    BorderThickness="0,0,0,1"
                    Padding="10">

                                <ContentPresenter
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- CELL -->
            <Style TargetType="DataGridCell">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- ROW -->
            <Style TargetType="DataGridRow">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Background" Value="#0F172A"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1E293B"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#334155"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

    </Grid>
</Window>
