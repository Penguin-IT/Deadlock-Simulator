<Window x:Class="Deadlock_simulator.Views.UI_Deadlock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helper="clr-namespace:Deadlock_simulator.Core"
        xmlns:local="clr-namespace:Deadlock_simulator.ViewModels"
        xmlns:models="clr-namespace:Deadlock_simulator.Models"
        mc:Ignorable="d"
        Title="UI_Deadlock" Height="766" Width="1491" Background="#0B1220">
    
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <models:CellColorConverter x:Key="CellColorConverter"/>
        <!-- BUTTON -->
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                        Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TEXTBOX -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,6,0,12"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <DropShadowEffect x:Key="ShadowEffect"
                          BlurRadius="10"
                          ShadowDepth="0"
                          Color="#000000"
                          Opacity="0.5"/>

    </Window.Resources>
    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- ===== BUTTON TOP ===== -->
        <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,0,0,20">

            <Button Content="Nạp File JSON" Background="#8B5CF6" Width="130" 
                    Style="{StaticResource BtnStyle}" Command="{Binding LoadJsonCommand}"/>

           
            <Button Content="Kiểm tra Banker"  Background="#22C55E" Width="130" 
                    Style="{StaticResource BtnStyle}" Command="{Binding CheckBankerCommand}"/>
            <Button Content="Phát hiện Deadlock"  Background="#F59E0B" Width="130" Visibility="Collapsed"
                    Style="{StaticResource BtnStyle}" Command="{Binding DetectDeadlockCommand}"/>
            <Button Content="Phục hồi Deadlock"  Background="#3B82F6" Width="130" Visibility="Collapsed"
                    Style="{StaticResource BtnStyle}" Command="{Binding RecoverDeadlockCommand}"/>
            
        </StackPanel>
        
        <!-- ===== INPUT PANEL ===== -->
        <Border Grid.Row="1" Grid.Column="0"
        Background="#1E293B"
        CornerRadius="15"
        Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                <StackPanel Margin="5">

                    <TextBlock Text="PROCESS" Foreground="#94A3B8" FontWeight="Bold" FontSize="14"/>
                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="+ Thêm Process"
                    Style="{StaticResource BtnStyle}"
                    Background="#6366F1"
                    Command="{Binding AddProcessCommand}"/>

                    <TextBlock Text="RESOURCE"
                       Foreground="#94A3B8"
                       FontWeight="Bold"
                       Margin="0,20,0,0"
                       FontSize="14"/>
                    <TextBox Style="{StaticResource TextBoxStyle}"
                     Text="{Binding NewResourceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="+ Thêm Resource"
                    Style="{StaticResource BtnStyle}"
                    Background="#6366F1"
                    Command="{Binding AddResourceCommand}"/>
                    <CheckBox Content="Tài nguyên dùng chung " 
          IsChecked="{Binding IsNewResourceShareable}" 
          Margin="0,10,0,10" 
          Foreground="White"/>

                    <Separator Margin="0,20"/>
                    <TextBlock Text="DANH SÁCH HIỆN TẠI"
                       Foreground="#94A3B8"
                       FontWeight="Bold"
                       Margin="0,10,0,5"/>

                    <TextBlock Text="• Processes" Foreground="White"/>
                    <ScrollViewer Height="80" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AllocationMatrix}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProcessName}" Foreground="#38BDF8" Margin="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Text="• Resources" Foreground="White" Margin="0,10,0,0"/>
                    <ScrollViewer Height="80" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Resources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#22C55E" Margin="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!--  (REQUEST) -->
                    <CheckBox Content="Bật Khiên Bảo Vệ (Banker &amp; Prevention)" 
          IsChecked="{Binding IsSafeModeEnabled}" 
          Foreground="White" 
          FontWeight="Bold" 
          Margin="0,0,0,10" />
                    <Separator Margin="0,20"/>
                    <TextBlock Text="CẤP PHÁT ĐỘNG (REQUEST)" Foreground="#E2E8F0" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>

                    <TextBlock Text="Chọn Tiến trình:" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AllocationMatrix}" DisplayMemberPath="ProcessName" 
                      SelectedValuePath="ProcessName" SelectedValue="{Binding SelectedProcessName, Mode=TwoWay}" 
                      Height="30" Margin="0,0,0,10"/>

                    <TextBlock Text="Chọn Tài nguyên:" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Resources}" 
                      SelectedValue="{Binding SelectedResourceName, Mode=TwoWay}" 
                      Height="30" Margin="0,0,0,10"/>

                    <TextBlock Text="Số lượng muốn xin:" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding RequestAmount, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}"/>

                    <Button Content="Gửi Yêu Cầu Xin Tài Nguyên" Style="{StaticResource BtnStyle}" 
                    Background="#10B981" Command="{Binding RequestResourceCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <!-- ===== DATAGRID AREA ===== -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- ===== ALLOCATION ===== -->
            <Border Grid.Row="0"
            CornerRadius="12"
            BorderBrush="#334155"
            BorderThickness="1"
            Background="#0F172A"
            Padding="10"
            Margin="0,0,0,15">
                <DockPanel>
                    <TextBlock Text="ALLOCATION"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       DockPanel.Dock="Top"/>
                    <DataGrid ItemsSource="{Binding AllocationMatrix}"
                      AutoGenerateColumns="False"
                      helper:DataGridHelper.BindableColumns="{Binding AllocationColumns}"
                      CanUserAddRows="False"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#334155"
                      VerticalGridLinesBrush="#334155">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">

                             
                                <Setter Property="Foreground" Value="White"/>

                                <Setter Property="TextBlock.TextAlignment" Value="Center"/>

                                
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource CellColorConverter}">

                                          
                                            <Binding />

                                            
                                            <Binding RelativeSource="{RelativeSource Self}" Path="Column.Header" />

                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>

                            </Style>
                        </DataGrid.CellStyle>
                    </DataGrid>
                </DockPanel>
            </Border>
            <!-- ===== MAX ===== -->
            <Border Grid.Row="1"
                    CornerRadius="12"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Background="#0F172A"
                    Padding="10"
                    Margin="0,0,0,15">
                <DockPanel>
                    <TextBlock Text="MAX"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               DockPanel.Dock="Top"/>
                    <DataGrid ItemsSource="{Binding MaxMatrix}"
                              AutoGenerateColumns="False"
                              helper:DataGridHelper.BindableColumns="{Binding MaxColumns}"
                              CanUserAddRows="False"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="#334155"
                              VerticalGridLinesBrush="#334155"/>
                </DockPanel>
            </Border>
            <!-- ===== AVAILABLE ===== -->
            <Border Grid.Row="2"
                    Background="#0F172A"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="AVAILABLE"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding AvailableResources}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#111827" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="8" Margin="5" Padding="10" Width="150">
                                    <StackPanel>
                                       
                                        <TextBlock Text="{Binding ResourceName}" Foreground="#38BDF8" FontWeight="Bold" HorizontalAlignment="Center" FontSize="14"/>

                                        
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                            <TextBlock Text="Bậc: " Foreground="#94A3B8" FontSize="11"/>
                                            <TextBlock Text="{Binding HierarchyOrder}" Foreground="#F59E0B" FontWeight="Bold" FontSize="11"/>
                                        </StackPanel>

                                        
                                        <Border CornerRadius="4" Padding="4,2" HorizontalAlignment="Center" Margin="0,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsShareable}" Value="True">
                                                            <Setter Property="Background" Value="#065F46"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsShareable}" Value="False">
                                                            <Setter Property="Background" Value="#991B1B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" Foreground="White" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsShareable}" Value="True">
                                                                <Setter Property="Text" Value="Dùng Chung"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsShareable}" Value="False">
                                                                <Setter Property="Text" Value="Độc Quyền"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <Separator Margin="0,8" Background="#334155"/>

                                        <TextBlock Text="Còn dư:" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Total}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== STYLE ===== -->
        <Grid.Resources>
            <!-- TEXTBOX -->
            <Style x:Key="TextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="0,6,0,12"/>
                <Setter Property="Background" Value="#0F172A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#6366F1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6"/>
            </Style>
            <!-- ===== DATAGRID STYLE ===== -->
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="#0F172A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowHeight" Value="45"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
            </Style>

            <!-- HEADER -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Border CornerRadius="5"
                        Background="#3B82F6"
                        Padding="10">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- CELL -->
            <Style TargetType="DataGridCell">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- ROW -->
            <Style TargetType="DataGridRow">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Background" Value="#0F172A"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1E293B"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#334155"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
    </Grid>
</Window>
